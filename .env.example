# ----- Database -----
# Trong Docker network: postgres:5432
# Khi chạy script từ host (qua container python tạm): dùng tên service
DATABASE_URL=postgresql://goodminton_prod:CHANGE_ME@postgres:5432/goodminton

# ----- Ollama -----
# Trong Docker network: http://ollama:11434
OLLAMA_URL=http://ollama:11434

# Embedding model (đã pull qua Ollama)
EMBEDDING_MODEL=bge-m3
